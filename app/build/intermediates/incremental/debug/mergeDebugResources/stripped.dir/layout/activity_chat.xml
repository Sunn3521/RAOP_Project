<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/whisprr_background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/chatToolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/whisprr_primary"
        app:titleTextColor="@color/whisprr_on_primary"
        app:subtitleTextColor="@color/whisprr_on_primary"
        app:navigationIconTint="@color/whisprr_on_primary"
        android:elevation="4dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"/>

    <!-- WhatsApp-style Input Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical"
        android:background="@color/whisprr_surface">

        <ImageButton
            android:id="@+id/btnAttach"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_add"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/whisprr_text_secondary"
            android:layout_marginEnd="6dp"
            android:contentDescription="Attach file"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_input_whatsapp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:gravity="center_vertical">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etMessageInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Type a message..."
                android:textColor="@color/whisprr_on_surface"
                android:textColorHint="@color/whisprr_text_muted"
                android:background="@null"
                android:maxLines="4"
                android:textSize="15sp"/>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnSend"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="6dp"
            android:src="@android:drawable/ic_menu_send"
            android:background="@drawable/bg_button_primary"
            android:padding="10dp"
            app:tint="@color/whisprr_on_primary"
            android:contentDescription="Send message"/>
    </LinearLayout>
</LinearLayout>
