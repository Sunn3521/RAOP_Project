<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_gradient_main">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/whisprr_status_bar"
        android:elevation="4dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Whisprr"
            app:titleTextColor="@color/whisprr_highlight"
            app:subtitle="Secure Ephemeral Chat"
            app:subtitleTextColor="@color/whisprr_text_secondary"/>
    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <!-- Hero Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_card_glass"
            android:padding="28dp"
            android:layout_marginBottom="40dp">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/logo"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Secure Ephemeral Chat"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/whisprr_on_surface"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Messages are encrypted end-to-end and deleted when the session ends"
                android:textAlignment="center"
                android:textSize="13sp"
                android:textColor="@color/whisprr_text_secondary"/>
        </LinearLayout>

        <!-- Action Buttons -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCreateChat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Create Chat"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/whisprr_on_primary"
            android:padding="16dp"
            app:backgroundTint="@null"
            android:background="@drawable/bg_button_primary"
            app:cornerRadius="24dp"
            app:icon="@android:drawable/ic_input_add"
            app:iconGravity="textStart"
            app:iconTint="@color/whisprr_on_primary"
            android:layout_marginBottom="16dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnJoinChat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Join Chat"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/whisprr_highlight"
            android:padding="16dp"
            app:backgroundTint="@null"
            android:background="@drawable/bg_button_secondary"
            app:cornerRadius="24dp"
            app:icon="@android:drawable/ic_menu_send"
            app:iconGravity="textStart"
            app:iconTint="@color/whisprr_highlight"/>

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="\uD83D\uDD12 End-to-end encrypted. No data stored on servers."
        android:textSize="11sp"
        android:textColor="@color/whisprr_text_muted"
        android:layout_gravity="center"
        android:layout_marginBottom="24dp"/>

</LinearLayout>
