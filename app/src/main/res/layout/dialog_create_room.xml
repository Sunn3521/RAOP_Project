<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center"
        android:background="@drawable/bg_dialog">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Room Code"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/whisprr_highlight"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Share this code with others to let them join"
            android:textSize="13sp"
            android:textColor="@color/whisprr_text_secondary"
            android:textAlignment="center"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Room Name (optional)"
            app:boxStrokeColor="@color/whisprr_primary_light"
            style="@style/Widget.Whisprr.TextInput"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etRoomName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapWords"
                android:maxLines="1"
                android:textColor="@color/whisprr_on_surface"/>
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_code_box"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvRoomCode"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ABCD1234"
                android:textSize="26sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:textColor="@color/whisprr_primary_light"
                android:ellipsize="end"
                android:maxLines="1" />

            <ImageButton
                android:id="@+id/btnCopyCode"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_copy"
                android:tint="@color/whisprr_primary"
                android:contentDescription="Copy code" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Delete data when session ends"
                android:textColor="@color/whisprr_text_secondary"
                android:textSize="14sp" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchDeleteOnEnd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="false" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEnterChat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enter Chat"
            android:textSize="16sp"
            android:textColor="@color/whisprr_on_primary"
            app:backgroundTint="@null"
            android:background="@drawable/bg_button_primary"
            app:cornerRadius="24dp" />

    </LinearLayout>
</layout>
