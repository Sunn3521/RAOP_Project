<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:background="@drawable/bg_card_glass"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tvParticipantName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Alice"
            android:textSize="15sp"
            android:textColor="@color/whisprr_on_surface" />

        <TextView
            android:id="@+id/tvHostBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HOST"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="@color/whisprr_primary_light"
            android:background="@drawable/bg_code_box"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:layout_marginEnd="8dp"
            android:visibility="gone" />

        <!-- Mute Badge (Mic Icon) -->
        <ImageView
            android:id="@+id/ivMuteBadge"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_mic"
            android:padding="6dp"
            android:layout_marginEnd="8dp"
            android:visibility="gone"
            android:contentDescription="Mute status" />

        <!-- Kick Badge (Red K) -->
        <TextView
            android:id="@+id/tvKickBadge"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="K"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:background="@drawable/bg_kick_badge"
            android:gravity="center"
            android:visibility="gone" />

        <!-- Old buttons - hidden but kept for compatibility -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMute"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mute"
            android:textSize="11sp"
            android:textColor="@color/whisprr_highlight"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:visibility="gone"
            android:minWidth="48dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnKick"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kick"
            android:textSize="11sp"
            android:textColor="@color/whisprr_error"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:visibility="gone"
            android:minWidth="48dp" />
    </LinearLayout>
</layout>
