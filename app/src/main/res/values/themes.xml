<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Whisprr" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/whisprr_primary</item>
        <item name="colorOnPrimary">@color/whisprr_on_primary</item>
        <item name="colorPrimaryContainer">@color/whisprr_primary_dark</item>
        <item name="colorSecondary">@color/whisprr_accent</item>
        <item name="colorSurface">@color/whisprr_surface</item>
        <item name="colorOnSurface">@color/whisprr_on_surface</item>
        <item name="android:windowBackground">@color/whisprr_background</item>
        <item name="android:statusBarColor">@color/whisprr_status_bar</item>
        <item name="android:navigationBarColor">@color/whisprr_status_bar</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="materialButtonStyle">@style/Widget.Whisprr.Button</item>
        <item name="textInputStyle">@style/Widget.Whisprr.TextInput</item>
    </style>

    <style name="Theme.Whisprr.SplashScreen" parent="Theme.Whisprr">
        <item name="android:windowIsTranslucent">true</item>
    </style>

    <style name="Widget.Whisprr.Button" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/whisprr_on_primary</item>
        <item name="backgroundTint">@color/whisprr_primary</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.Whisprr.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/whisprr_primary_light</item>
        <item name="strokeWidth">2dp</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:textColor">@color/whisprr_highlight</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="Widget.Whisprr.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/whisprr_primary_light</item>
        <item name="hintTextColor">@color/whisprr_text_secondary</item>
        <item name="android:textColorHint">@color/whisprr_input_hint</item>
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
    </style>

    <style name="Widget.Whisprr.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/whisprr_surface_elevated</item>
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">8dp</item>
        <item name="strokeColor">@color/whisprr_glass_border</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Dialog.Whisprr" parent="Theme.Material3.Dark.Dialog.Alert">
        <item name="colorPrimary">@color/whisprr_primary</item>
        <item name="colorSurface">@color/whisprr_surface</item>
        <item name="android:windowBackground">@drawable/bg_dialog</item>
        <item name="dialogCornerRadius">24dp</item>
    </style>
</resources>

